{
  "title": "AIOps Quality Service",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Requests per minute",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(inference_requests_total[1m])) * 60",
          "legendFormat": "rpm"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "P95 latency (seconds)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(inference_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total drift events",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(inference_drift_events_total)",
          "legendFormat": "drift"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Drift events per minute",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(inference_drift_events_total[1m])) * 60",
          "legendFormat": "drift/min"
        }
      ]
    }
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-15m",
    "to": "now"
  }
}
